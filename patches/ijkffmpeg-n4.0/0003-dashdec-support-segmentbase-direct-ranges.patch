From 1e19c3664ee1410c8a7f1f5a9dabd3aca4bee175 Mon Sep 17 00:00:00 2001
From: FFToolChain <fftoolchain@localhost>
Date: Tue, 28 Apr 2026 18:58:38 +0800
Subject: [PATCH] dashdec: support SegmentBase direct range requests

---
 libavformat/dashdec.c | 171 ++++++++++++++++++++++++++++++++++++++++--
 1 file changed, 166 insertions(+), 5 deletions(-)

diff --git a/libavformat/dashdec.c b/libavformat/dashdec.c
index 58d19cb..b193f4c 100644
--- a/libavformat/dashdec.c
+++ b/libavformat/dashdec.c
@@ -144,6 +144,7 @@ typedef struct DASHContext {
     int is_live;
     AVIOInterruptCB *interrupt_callback;
     char *user_agent;                    ///< holds HTTP user agent set as an AVOption to the HTTP protocol context
+    char *referer;                       ///< holds HTTP referer set as an AVOption to the HTTP protocol context
     char *cookies;                       ///< holds HTTP cookie values set in either the initial response or as an AVOption to the HTTP protocol context
     char *headers;                       ///< holds HTTP headers set as an AVOption to the HTTP protocol context
     char *allowed_extensions;
@@ -378,6 +379,7 @@ static void set_httpheader_options(DASHContext *c, AVDictionary **opts)
     // http.c supports "user_agent" and (deprecated) "user-agent".
     av_dict_set(opts, "user_agent", c->user_agent, 0);
     av_dict_set(opts, "user-agent", c->user_agent, 0);
+    av_dict_set(opts, "referer", c->referer, 0);
     av_dict_set(opts, "cookies", c->cookies, 0);
     av_dict_set(opts, "headers", c->headers, 0);
     if (c->is_live) {
@@ -576,21 +578,153 @@ static enum AVMediaType get_content_type(xmlNodePtr node)
 static struct fragment * get_Fragment(char *range)
 {
     struct fragment * seg =  av_mallocz(sizeof(struct fragment));
+    int64_t end_offset;
+    char *str_end_offset;
+    char *str_offset;
 
     if (!seg)
         return NULL;
 
     seg->size = -1;
     if (range) {
-        char *str_end_offset;
-        char *str_offset = av_strtok(range, "-", &str_end_offset);
+        str_offset = av_strtok(range, "-", &str_end_offset);
+        if (!str_offset || !str_end_offset || !*str_end_offset) {
+            av_free(seg);
+            return NULL;
+        }
         seg->url_offset = strtoll(str_offset, NULL, 10);
-        seg->size = strtoll(str_end_offset, NULL, 10) - seg->url_offset;
+        end_offset = strtoll(str_end_offset, NULL, 10);
+        if (end_offset < seg->url_offset) {
+            av_free(seg);
+            return NULL;
+        }
+        seg->size = end_offset - seg->url_offset + 1;
     }
 
     return seg;
 }
 
+static int64_t get_fragment_end_offset(struct fragment *seg)
+{
+    if (!seg || seg->size < 0)
+        return -1;
+
+    return seg->url_offset + seg->size - 1;
+}
+
+static int parse_manifest_segmentbase(AVFormatContext *s, struct representation *rep,
+                                      xmlNodePtr segmentbase_node,
+                                      xmlNodePtr *baseurl_nodes,
+                                      char *rep_id_val,
+                                      char *rep_bandwidth_val)
+{
+    DASHContext *c = s->priv_data;
+    xmlNodePtr initialization_node = NULL;
+    struct fragment *init_section = NULL;
+    struct fragment *index_section = NULL;
+    struct fragment *media = NULL;
+    char *index_range = NULL;
+    char *initialization_source = NULL;
+    char *initialization_range = NULL;
+    int64_t bootstrap_start = INT64_MAX;
+    int64_t bootstrap_end = -1;
+    int64_t current_end;
+    int max_url_size = c ? c->max_url_size : MAX_URL_SIZE;
+    int ret = 0;
+
+    initialization_node = find_child_node_by_name(segmentbase_node, "Initialization");
+    if (initialization_node) {
+        initialization_source = xmlGetProp(initialization_node, "sourceURL");
+        initialization_range = xmlGetProp(initialization_node, "range");
+        if (initialization_source || initialization_range) {
+            init_section = get_Fragment(initialization_range);
+            if (!init_section) {
+                ret = AVERROR_INVALIDDATA;
+                goto cleanup;
+            }
+            init_section->url = get_content_url(baseurl_nodes, 4,
+                                                max_url_size,
+                                                rep_id_val,
+                                                rep_bandwidth_val,
+                                                initialization_source);
+            if (!init_section->url) {
+                ret = AVERROR(ENOMEM);
+                goto cleanup;
+            }
+            current_end = get_fragment_end_offset(init_section);
+            if (current_end >= 0) {
+                bootstrap_start = FFMIN(bootstrap_start, init_section->url_offset);
+                bootstrap_end = FFMAX(bootstrap_end, current_end);
+            }
+        }
+    }
+
+    index_range = xmlGetProp(segmentbase_node, "indexRange");
+    if (index_range) {
+        index_section = get_Fragment(index_range);
+        if (!index_section) {
+            ret = AVERROR_INVALIDDATA;
+            goto cleanup;
+        }
+        current_end = get_fragment_end_offset(index_section);
+        if (current_end >= 0) {
+            bootstrap_start = FFMIN(bootstrap_start, index_section->url_offset);
+            bootstrap_end = FFMAX(bootstrap_end, current_end);
+        }
+    }
+
+    media = av_mallocz(sizeof(struct fragment));
+    if (!media) {
+        ret = AVERROR(ENOMEM);
+        goto cleanup;
+    }
+    media->url = get_content_url(baseurl_nodes, 4,
+                                 max_url_size,
+                                 rep_id_val,
+                                 rep_bandwidth_val,
+                                 NULL);
+    if (!media->url) {
+        ret = AVERROR(ENOMEM);
+        goto cleanup;
+    }
+    media->size = -1;
+    if (bootstrap_end >= 0)
+        media->url_offset = bootstrap_end + 1;
+
+    if (init_section && bootstrap_end >= 0 && !strcmp(init_section->url, media->url)) {
+        init_section->url_offset = bootstrap_start;
+        init_section->size = bootstrap_end - bootstrap_start + 1;
+    } else if (bootstrap_end >= 0 && !init_section) {
+        av_log(s, AV_LOG_WARNING,
+               "DASH SegmentBase is missing Initialization for representation %s\n",
+               rep_id_val ? rep_id_val : "");
+    }
+
+    if (init_section)
+        rep->init_section = init_section;
+    dynarray_add(&rep->fragments, &rep->n_fragments, media);
+    av_log(s, AV_LOG_VERBOSE,
+           "DASH SegmentBase bootstrap [%"PRId64",%"PRId64"], media start %"PRId64", representation %s\n",
+           bootstrap_start == INT64_MAX ? -1 : bootstrap_start,
+           bootstrap_end,
+           media->url_offset,
+           rep_id_val ? rep_id_val : "");
+    media = NULL;
+    init_section = NULL;
+
+cleanup:
+    free_fragment(&init_section);
+    free_fragment(&index_section);
+    free_fragment(&media);
+    if (initialization_source)
+        xmlFree(initialization_source);
+    if (initialization_range)
+        xmlFree(initialization_range);
+    if (index_range)
+        xmlFree(index_range);
+    return ret;
+}
+
 static int parse_manifest_segmenturlnode(AVFormatContext *s, struct representation *rep,
                                          xmlNodePtr fragmenturl_node,
                                          xmlNodePtr *baseurl_nodes,
@@ -819,6 +953,8 @@ static int parse_manifest_representation(AVFormatContext *s, const char *url,
     xmlNodePtr representation_segmenttemplate_node = NULL;
     xmlNodePtr representation_baseurl_node = NULL;
     xmlNodePtr representation_segmentlist_node = NULL;
+    xmlNodePtr representation_segmentbase_node = NULL;
+    xmlNodePtr adaptionset_segmentbase_node = NULL;
     xmlNodePtr segmentlists_tab[2];
     xmlNodePtr fragment_timeline_node = NULL;
     xmlNodePtr fragment_templates_tab[5];
@@ -857,6 +993,8 @@ static int parse_manifest_representation(AVFormatContext *s, const char *url,
         representation_segmenttemplate_node = find_child_node_by_name(representation_node, "SegmentTemplate");
         representation_baseurl_node = find_child_node_by_name(representation_node, "BaseURL");
         representation_segmentlist_node = find_child_node_by_name(representation_node, "SegmentList");
+        representation_segmentbase_node = find_child_node_by_name(representation_node, "SegmentBase");
+        adaptionset_segmentbase_node = find_child_node_by_name(adaptionset_node, "SegmentBase");
 
         baseurl_nodes[0] = mpd_baseurl_node;
         baseurl_nodes[1] = period_baseurl_node;
@@ -954,6 +1092,16 @@ static int parse_manifest_representation(AVFormatContext *s, const char *url,
                     fragment_timeline_node = xmlNextElementSibling(fragment_timeline_node);
                 }
             }
+        } else if ((representation_segmentbase_node || adaptionset_segmentbase_node) &&
+                   representation_baseurl_node && !representation_segmentlist_node) {
+            ret = parse_manifest_segmentbase(s, rep,
+                                             representation_segmentbase_node ? representation_segmentbase_node
+                                                                             : adaptionset_segmentbase_node,
+                                             baseurl_nodes,
+                                             rep_id_val,
+                                             rep_bandwidth_val);
+            if (ret < 0)
+                goto end;
         } else if (representation_baseurl_node && !representation_segmentlist_node) {
             seg = av_mallocz(sizeof(struct fragment));
             if (!seg) {
@@ -1574,10 +1722,12 @@ static int open_input(DASHContext *c, struct representation *pls, struct fragmen
         goto cleanup;
     }
     set_httpheader_options(c, &opts);
-    if (seg->size >= 0) {
+    if (seg->url_offset > 0) {
         /* try to restrict the HTTP request to the part we want
          * (if this is in fact a HTTP request) */
         av_dict_set_int(&opts, "offset", seg->url_offset, 0);
+    }
+    if (seg->size >= 0) {
         av_dict_set_int(&opts, "end_offset", seg->url_offset + seg->size, 0);
     }
 
@@ -1830,7 +1980,7 @@ end:
 static int save_avio_options(AVFormatContext *s)
 {
     DASHContext *c = s->priv_data;
-    const char *opts[] = { "headers", "user_agent", "user-agent", "cookies", NULL }, **opt = opts;
+    const char *opts[] = { "headers", "user_agent", "user-agent", "referer", "cookies", NULL }, **opt = opts;
     uint8_t *buf = NULL;
     int ret = 0;
 
@@ -1981,6 +2131,7 @@ static int dash_read_header(AVFormatContext *s)
 {
     void *u = (s->flags & AVFMT_FLAG_CUSTOM_IO) ? NULL : s->pb;
     DASHContext *c = s->priv_data;
+    const char *mpd_proto = avio_find_protocol_name(s->filename);
     int ret = 0;
     int stream_index = 0;
     int i;
@@ -1994,12 +2145,19 @@ static int dash_read_header(AVFormatContext *s)
             if (!c->user_agent)
                 update_options(&c->user_agent, "user-agent", u);
         }
+        if (!c->referer)
+            update_options(&c->referer, "referer", u);
         if (!c->cookies)
             update_options(&c->cookies, "cookies", u);
         if (!c->headers)
             update_options(&c->headers, "headers", u);
     }
 
+    av_log(s, AV_LOG_INFO,
+           "DASH option bridge: mpd_proto=%s ua=%d referer=%d headers=%d cookies=%d\n",
+           mpd_proto ? mpd_proto : "unknown",
+           !!c->user_agent, !!c->referer, !!c->headers, !!c->cookies);
+
     if ((ret = parse_manifest(s, s->filename, s->pb)) < 0)
         goto fail;
 
@@ -2156,6 +2314,7 @@ static int dash_close(AVFormatContext *s)
     free_video_list(c);
 
     av_freep(&c->cookies);
+    av_freep(&c->referer);
     av_freep(&c->user_agent);
     av_freep(&c->headers);
     av_dict_free(&c->avio_opts);
@@ -2283,6 +2442,8 @@ static const AVOption dash_options[] = {
         OFFSET(user_agent), AV_OPT_TYPE_STRING, { .str = NULL }, 0, 0, FLAGS},
     {"user-agent", "override User-Agent header (alias for user_agent)",
         OFFSET(user_agent), AV_OPT_TYPE_STRING, { .str = NULL }, 0, 0, FLAGS},
+    {"referer", "override Referer header (applies to DASH sub-requests too)",
+        OFFSET(referer), AV_OPT_TYPE_STRING, { .str = NULL }, 0, 0, FLAGS},
     {"cookies", "set cookies (applies to DASH sub-requests too)",
         OFFSET(cookies), AV_OPT_TYPE_STRING, { .str = NULL }, 0, 0, FLAGS},
     {"allowed_extensions", "List of file extensions that dash is allowed to access",
-- 
