From 2e8f1a6660d4e12f08215c5428965fa3d6a3f13f Mon Sep 17 00:00:00 2001
From: FFToolChain <fftoolchain@localhost>
Date: Wed, 29 Apr 2026 12:48:01 +0800
Subject: [PATCH] dashdec: map SegmentBase media seeks

---
 libavformat/dashdec.c | 51 +++++++++++++++++++++++++++++++++++--------
 1 file changed, 42 insertions(+), 9 deletions(-)

diff --git a/libavformat/dashdec.c b/libavformat/dashdec.c
index 7e44c2dd51..628cedc050 100644
--- a/libavformat/dashdec.c
+++ b/libavformat/dashdec.c
@@ -1847,18 +1847,29 @@ static int ensure_media_input(struct representation *v)
     return open_input(c, v, v->cur_seg);
 }
 
-static int64_t get_virtual_stream_size(struct representation *v)
+static int64_t get_media_stream_size(struct representation *v)
 {
     int64_t media_size = -1;
+    int64_t urlsize;
 
     if (v->cur_seg_size >= 0) {
         media_size = v->cur_seg_size;
     } else if (v->cur_seg && v->cur_seg->size >= 0) {
         media_size = v->cur_seg->size;
-    } else if (v->input) {
-        media_size = avio_size(v->input);
+    } else if (v->input && (urlsize = avio_size(v->input)) >= 0) {
+        if (v->cur_seg && v->cur_seg->url_offset > 0 && urlsize >= v->cur_seg->url_offset)
+            media_size = urlsize - v->cur_seg->url_offset;
+        else
+            media_size = urlsize;
     }
 
+    return media_size;
+}
+
+static int64_t get_virtual_stream_size(struct representation *v)
+{
+    int64_t media_size = get_media_stream_size(v);
+
     if (media_size < 0)
         return media_size;
 
@@ -1881,7 +1892,9 @@ static int64_t seek_data(void *opaque, int64_t offset, int whence)
     struct representation *v = opaque;
     int64_t current_pos;
     int64_t stream_size;
+    int64_t media_size;
     int64_t media_offset;
+    int64_t absolute_offset;
     int64_t seek_ret;
     int ret;
 
@@ -1917,7 +1930,8 @@ static int64_t seek_data(void *opaque, int64_t offset, int whence)
     if (v->init_sec_data_len && offset < v->init_sec_data_len) {
         v->init_sec_buf_read_offset = offset;
         if (v->input) {
-            seek_ret = avio_seek(v->input, 0, SEEK_SET);
+            absolute_offset = v->cur_seg ? v->cur_seg->url_offset : 0;
+            seek_ret = avio_seek(v->input, absolute_offset, SEEK_SET);
             if (seek_ret < 0)
                 return seek_ret;
             v->cur_seg_offset = 0;
@@ -1934,14 +1948,33 @@ static int64_t seek_data(void *opaque, int64_t offset, int whence)
 
     v->init_sec_buf_read_offset = v->init_sec_data_len;
     media_offset = offset - v->init_sec_data_len;
-    seek_ret = avio_seek(v->input, media_offset, SEEK_SET);
+    media_size = get_media_stream_size(v);
+    if (media_size >= 0) {
+        if (media_offset > media_size)
+            return AVERROR(EINVAL);
+        if (media_offset == media_size) {
+            v->cur_seg_offset = media_size;
+            av_log(v->parent, AV_LOG_VERBOSE,
+                   "DASH virtual seek -> media EOF (virtual %"PRId64"), playlist %d\n",
+                   (int64_t)v->init_sec_data_len + media_size, v->rep_idx);
+            return (int64_t)v->init_sec_data_len + media_size;
+        }
+    }
+
+    absolute_offset = media_offset;
+    if (v->cur_seg && v->cur_seg->url_offset > 0)
+        absolute_offset += v->cur_seg->url_offset;
+    seek_ret = avio_seek(v->input, absolute_offset, SEEK_SET);
     if (seek_ret < 0)
         return seek_ret;
-    v->cur_seg_offset = seek_ret;
+    if (v->cur_seg && v->cur_seg->url_offset > 0 && seek_ret >= v->cur_seg->url_offset)
+        v->cur_seg_offset = seek_ret - v->cur_seg->url_offset;
+    else
+        v->cur_seg_offset = seek_ret;
     av_log(v->parent, AV_LOG_VERBOSE,
-           "DASH virtual seek -> media offset %"PRId64" (virtual %"PRId64"), playlist %d\n",
-           seek_ret, (int64_t)v->init_sec_data_len + seek_ret, v->rep_idx);
-    return (int64_t)v->init_sec_data_len + seek_ret;
+           "DASH virtual seek -> media offset %"PRId64" absolute %"PRId64" (virtual %"PRId64"), playlist %d\n",
+           v->cur_seg_offset, seek_ret, (int64_t)v->init_sec_data_len + v->cur_seg_offset, v->rep_idx);
+    return (int64_t)v->init_sec_data_len + v->cur_seg_offset;
 
     return AVERROR(ENOSYS);
 }
