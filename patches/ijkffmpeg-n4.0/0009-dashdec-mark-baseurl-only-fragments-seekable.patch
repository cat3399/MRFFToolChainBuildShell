From 9c7d6240233c10d0fb2bc205ccac4f879ceffdb3 Mon Sep 17 00:00:00 2001
From: FFToolChain <fftoolchain@localhost>
Date: Sun, 3 May 2026 03:10:00 +0800
Subject: [PATCH] dashdec: mark BaseURL-only fragments seekable

BaseURL-only DASH VOD represents each track as one complete media
resource. Let the nested MOV/MP4 demuxer seek through dashdec's custom IO
so single-file .m4s URLs from app playurl can be parsed and seeked natively.
SegmentBase playlists still keep dashdec-owned fragment boundaries.
---
 libavformat/dashdec.c | 19 ++++++++++++++++++-
 1 file changed, 18 insertions(+), 1 deletion(-)

diff --git a/libavformat/dashdec.c b/libavformat/dashdec.c
index fd9754d..43ae046 100644
--- a/libavformat/dashdec.c
+++ b/libavformat/dashdec.c
@@ -1816,10 +1816,22 @@ static int update_init_section(struct representation *pls)
     return 0;
 }
 
+static int is_single_full_fragment_representation(struct representation *pls)
+{
+    return pls &&
+           pls->n_fragments == 1 &&
+           !pls->init_section &&
+           pls->fragments &&
+           pls->fragments[0] &&
+           pls->fragments[0]->size < 0;
+}
+
 static int64_t seek_data(void *opaque, int64_t offset, int whence)
 {
     struct representation *v = opaque;
-    if (v->n_fragments && !v->init_sec_data_len) {
+    if (v->input &&
+        is_single_full_fragment_representation(v) &&
+        !v->init_sec_data_len) {
         return avio_seek(v->input, offset, whence);
     }
 
@@ -1945,7 +1958,10 @@ static int reopen_demux_for_component(AVFormatContext *s, struct representation
     } else {
         ffio_init_context(&pls->pb, avio_ctx_buffer , INITIAL_BUFFER_SIZE, 0, pls, read_data, NULL, seek_data);
     }
-    pls->pb.seekable = 0;
+    if (is_single_full_fragment_representation(pls))
+        pls->pb.seekable = AVIO_SEEKABLE_NORMAL;
+    else
+        pls->pb.seekable = 0;
 
     if ((ret = ff_copy_whiteblacklists(pls->ctx, s)) < 0)
         goto fail;
