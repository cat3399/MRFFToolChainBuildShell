From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Codex <codex@openai.com>
Date: Thu, 16 Jul 2026 00:00:00 +0800
Subject: [PATCH] configure: fix libxml2 pkg-config header probe

libxml-2.0.pc adds include/libxml2 to the compiler search path, so the
probe must use libxml/xmlversion.h. Using libxml2/libxml/xmlversion.h
duplicates the directory and fails with current libxml2 releases.
---
 configure | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/configure b/configure
index a23a7e2..ee13c20 100755
--- a/configure
+++ b/configure
@@ -6089,7 +6089,7 @@ enabled libvmaf           && require_pkg_config libvmaf "libvmaf >= 1.3.9" libvm
 enabled libvorbis         && require_pkg_config libvorbis vorbis vorbis/codec.h vorbis_info_init &&
                              require_pkg_config libvorbisenc vorbisenc vorbis/vorbisenc.h vorbis_encode_init
 enabled libvpx            && require_pkg_config libvpx "vpx >= 1.4.0" vpx/vpx_codec.h vpx_codec_version &&
-enabled libxml2           && require_pkg_config libxml2 libxml-2.0 libxml2/libxml/xmlversion.h xmlCheckVersion
+enabled libxml2           && require_pkg_config libxml2 libxml-2.0 libxml/xmlversion.h xmlCheckVersion
 enabled libzimg           && require_pkg_config libzimg "zimg >= 2.7.0" zimg.h zimg_get_api_version
 enabled libzmq            && require_pkg_config libzmq libzmq zmq.h zmq_ctx_new
 enabled libzvbi           && require_pkg_config libzvbi zvbi-0.2 libzvbi.h vbi_decoder_new &&
-- 
2.47.3

